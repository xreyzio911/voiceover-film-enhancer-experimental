AUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Audio Track Splitter backend engine
AUDIO_SPLITTER_ENGINE=audio-separator
AUDIO_SPLITTER_AUDIO_SEPARATOR_COMMAND=.venv-audio-splitter\Scripts\python.exe
AUDIO_SPLITTER_AUDIO_SEPARATOR_MODEL=model_bs_roformer_ep_317_sdr_12.9755.ckpt
AUDIO_SPLITTER_AUDIO_SEPARATOR_MODEL_DIR=.audio-separator-models
AUDIO_SPLITTER_DEVICE=cpu
AUDIO_SPLITTER_OUTPUT_BIT_DEPTH=16
AUDIO_SPLITTER_AUDIO_SEPARATOR_SAMPLE_RATE=44100
AUDIO_SPLITTER_AUDIO_SEPARATOR_NORMALIZATION=0.98
AUDIO_SPLITTER_AUDIO_SEPARATOR_CHUNK_DURATION=30
AUDIO_SPLITTER_AUDIO_SEPARATOR_USE_SOUNDFILE=1
AUDIO_SPLITTER_AUDIO_SEPARATOR_USE_AUTOCAST=0

# Fallback engine: set AUDIO_SPLITTER_ENGINE=demucs to use these.
AUDIO_SPLITTER_DEMUCS_COMMAND=python.exe -m demucs
AUDIO_SPLITTER_DEMUCS_MODEL=htdemucs
AUDIO_SPLITTER_DEMUCS_DEVICE=cpu
AUDIO_SPLITTER_DEMUCS_SEGMENT=7
AUDIO_SPLITTER_DEMUCS_SHIFTS=1

# Neural speech enhancement pass. The app renders first, enhancement runs once, then the app renders again before export.
# Local Windows: .venv-neural\Scripts\python.exe. Vercel/Linux: python3 or .venv-neural/bin/python with ClearVoice installed.
VO_NEURAL_REPAIR_ENABLED=on
VO_NEURAL_REPAIR_COMMAND=.venv-neural\Scripts\python.exe
# Vercel's Next.js Node runtime cannot spawn Python. Point this at a persistent ClearVoice worker instead.
VO_NEURAL_REPAIR_REMOTE_URL=
VO_NEURAL_REPAIR_REMOTE_TOKEN=
VO_NEURAL_REPAIR_ENGINE=clearvoice
VO_NEURAL_REPAIR_DEVICE=cpu
VO_NEURAL_REPAIR_MAX_AUDIO_MB=350
VO_NEURAL_REPAIR_TIMEOUT_SECONDS=2700
VO_NEURAL_REPAIR_TORCH_THREADS=2
VO_NEURAL_REPAIR_SPEECH_AWARE=on
VO_NEURAL_REPAIR_SPEECH_AWARE_MIN_SECONDS=90
VO_NEURAL_REPAIR_SPEECH_AWARE_MAX_DUTY_PCT=62
VO_NEURAL_REPAIR_SPEECH_AWARE_PAD_MS=360
VO_NEURAL_REPAIR_SPEECH_AWARE_MERGE_GAP_MS=900
VO_NEURAL_REPAIR_SPEECH_AWARE_FADE_MS=80
NEXT_PUBLIC_VO_NEURAL_SPEECH_ENHANCEMENT_DEFAULT=on

# Gemini AI review. Keep keys server-side only; the browser sends bounded QC/profile summaries to /api/audio-review.
GEMINI_API_KEY=
GEMINI_AUDIO_REVIEW_MODEL=gemini-3.1-flash-lite
GEMINI_AUDIO_REVIEW_TIMEOUT_MS=45000
